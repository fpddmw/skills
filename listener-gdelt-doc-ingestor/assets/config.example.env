# Copy to your local secret env file (do not commit real secrets)

# Required when --classify-mode llm
LLM_API_KEY=your_api_key_here

# Optional overrides (if not supplied by your runtime config system)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional DB path for this skill
GDELT_ENV_DB_PATH=/absolute/path/to/workspace/gdelt_environment.db
