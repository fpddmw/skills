# Copy to your local env file and keep secrets out of git.

# Required for OpenAQ API v3
OPENAQ_API_KEY=your_openaq_api_key_here

# OpenAQ runtime defaults
OPENAQ_API_BASE_URL=https://api.openaq.org/v3
OPENAQ_TIMEOUT_SECONDS=20
OPENAQ_PAGE_LIMIT=100
OPENAQ_MAX_PAGES=20
OPENAQ_SLEEP_MS=1100
OPENAQ_USER_AGENT=observer-global-aqi-ingestor/1.0

# Local SQLite path
OBSERVER_DB_PATH=/absolute/path/to/workspace/observer_physical.db

# Optional: observer planner (scripts/observer_plan.py) can reuse the same OpenAI-compatible LLM env.
# Example (reuse moderator/listener style keys):
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_or_compatible_api_key_here
LLM_MODEL=gpt-4o-mini

# Optional CAMS fallback planning variables
CAMS_ADS_URL=https://ads.atmosphere.copernicus.eu/api
CAMS_ADS_PAT=your_ads_pat_here
CAMS_DATASET=
CAMS_FORMAT=netcdf
